# QuizRush Environment Variables
# WARNING: Never put a real connection string or password as a source-code fallback.
# Fallbacks in code should only ever point at localhost (e.g. postgresql://postgres:postgres@localhost:5432/quizrush).

# PostgreSQL Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quizrush

# Valkey Connection URL
VALKEY_URL=redis://localhost:6379

# Session Secret (Required for cookie signing)
SESSION_SECRET=super-secret-key-change-in-production

# Room TTL Default
ROOM_TTL_SECONDS=7200
